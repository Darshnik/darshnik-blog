---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';
import { getReadingTime } from '../utils/readingTime';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const featuredPosts = allPosts
  .filter(post => post.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Fall back to latest posts if none are featured
const postsToShow = featuredPosts.length > 0
  ? featuredPosts
  : allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<section class="py-16 md:py-24">
  <div class="max-w-[1080px] mx-auto px-6">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-[var(--color-text)] dark:text-[var(--color-dark-text)]">
        Selected Essays
      </h2>
      <a href="/blog" class="text-sm text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] hover:text-[var(--color-accent-hover)] dark:hover:text-[var(--color-dark-accent-hover)] transition-colors">
        View all writing &rarr;
      </a>
    </div>
    <div class="divide-y divide-[var(--color-border)] dark:divide-[var(--color-dark-border)]">
      {postsToShow.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          readingTime={post.data.readingTime || getReadingTime(post.body || '')}
          slug={post.id}
        />
      ))}
    </div>
  </div>
</section>
